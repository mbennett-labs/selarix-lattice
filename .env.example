# SELARIX Lattice — environment variable template
# Copy to .env and fill in real values
# .env is gitignored; never commit real secrets

# Model backend (daily driver)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Telegram bot (Reporter output channel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Project state locations
LATTICE_ROOT=/opt/selarix/lattice
PROJECTS_ROOT=/opt/selarix/projects
