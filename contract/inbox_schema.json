{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SELARIX Lattice Board Directive",
  "type": "object",
  "required": ["directive_id", "timestamp", "board_source", "command", "content"],
  "properties": {
    "directive_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "board_source": { "type": "string" },
    "command": { "type": "string", "enum": ["approve", "kill", "priority", "note", "free-form"] },
    "target": { "type": "string" },
    "content": { "type": "string" }
  }
}
