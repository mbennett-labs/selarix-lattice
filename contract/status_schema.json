{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SELARIX Lattice Project Status",
  "type": "object",
  "required": ["project_name", "date", "completed", "in_progress", "blocked"],
  "properties": {
    "project_name": { "type": "string" },
    "date": { "type": "string", "format": "date" },
    "completed": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "agent": { "type": "string" },
          "task": { "type": "string" },
          "detail": { "type": "string" },
          "time": { "type": "string", "format": "date-time" }
        }
      }
    },
    "in_progress": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "agent": { "type": "string" },
          "task": { "type": "string" },
          "eta": { "type": "string", "format": "date" }
        }
      }
    },
    "blocked": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "issue": { "type": "string" },
          "needs": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
        }
      }
    },
    "revenue_events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "amount_usd": { "type": "number" }
        }
      }
    },
    "flags_for_board": {
      "type": "array",
      "items": { "type": "string" }
    },
    "health_signals": {
      "type": "object",
      "properties": {
        "uptime_pct": { "type": "number" },
        "agent_errors": { "type": "integer" }
      }
    }
  }
}
